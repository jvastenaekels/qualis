# Copy to .env.production, fill every empty value, and keep the file private.

# Public URL and nginx Host-header allowlist. Use [.] for literal dots in the regex.
FRONTEND_URL=https://qualis.example.org
ALLOWED_ORIGINS=https://qualis.example.org
QUALIS_ALLOWED_HOST_PATTERN=^(qualis[.]example[.]org)$
QUALIS_HTTP_PORT=3000

# Generate each secret independently with: openssl rand -hex 32
QUALIS_DB_PASSWORD=
SECRET_KEY=
IP_HASH_SALT=

# Initial owner, created only when the database has no users.
ADMIN_EMAIL=
ADMIN_PASSWORD=
