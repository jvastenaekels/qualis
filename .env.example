# =============================================================================
# Qualis environment variables — copy to `.env` and edit values
# =============================================================================
#
# Quick start (local development):
#   1. cp .env.example .env
#   2. Edit DATABASE_URL with your local Postgres connection string
#   3. Generate SECRET_KEY and IP_HASH_SALT (see "Generating secrets" below)
#   4. Set ENVIRONMENT=development to enable test/dev routes
#   5. Run `make install`, `make migrate`, `make run-backend`, `make run-frontend`
#
# `.env` is gitignored — never commit real credentials.
#
# Generating secrets (Python):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# =============================================================================


# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------

# Must be one of: production | development | test
# - "production" disables /api/test/* routes (E2E test endpoints)
# - "development" enables /api/test/* (unauthenticated; never use in production)
# - "test" used by pytest (set automatically via TESTING env var)
# Default in code is "production" (fail-closed).
ENVIRONMENT=development


# -----------------------------------------------------------------------------
# Security secrets (REQUIRED for any non-development deployment)
# -----------------------------------------------------------------------------

# JWT signing key. Used to sign access tokens.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGEME-insecure-dev-only

# Salt for hashing client IP addresses (used in audit logs / rate limiting
# while preserving participant privacy under RGPD).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
IP_HASH_SALT=CHANGEME-insecure-dev-only

# Access token lifetime in minutes. 480 = 8 hours.
ACCESS_TOKEN_EXPIRE_MINUTES=480


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres async connection string for the application.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Matches the `qualis_user` / `qualis_dev` role the README asks you to create.
DATABASE_URL=postgresql+asyncpg://qualis_user:qualis_pass@localhost:5432/qualis_dev

# Separate Postgres URL for the test suite. Pytest fixtures will reset this
# DB between runs; never point this at a database with real data.
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qualis_test


# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------

# Public URL of the frontend (used in emails and CORS).
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed origins for CORS in production.
# Leave empty to allow only FRONTEND_URL.
# Example: ALLOWED_ORIGINS=https://qualis.example.org,https://staging.qualis.example.org
ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Rate-limiter trust model
# -----------------------------------------------------------------------------
# Trust X-Forwarded-For ONLY when the immediate TCP peer is in this list,
# or set to `*` to trust unconditionally (do this only when you are sure
# the deployment is behind a reverse proxy / load balancer you control).
# Empty (default) = ignore the header, key the rate limiter on the direct
# TCP peer. Safe for direct-exposed deployments.
#
# Examples:
#   TRUSTED_PROXIES=*                          # behind Scalingo / Heroku / Render
#   TRUSTED_PROXIES=10.0.0.1,10.0.0.2          # specific reverse proxy IPs

TRUSTED_PROXIES=


# -----------------------------------------------------------------------------
# Error reporting (optional — Sentry)
# -----------------------------------------------------------------------------
# Leave SENTRY_DSN / VITE_SENTRY_DSN empty to disable. When set, errors are
# reported to Sentry tagged with ENVIRONMENT / VITE_ENVIRONMENT.
# send_default_pii is hardcoded to false in both backend and frontend
# (RGPD: participant emails / IPs are never forwarded).
#
# Backend (server-side) — reads at runtime:
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Frontend (browser-side) — baked in at build time by Vite.
# Set VITE_SENTRY_DSN in your CI/CD environment before running `npm run build`.
# Leave empty in development to keep Sentry silent locally.
VITE_SENTRY_DSN=
# Optional: override the environment tag sent to Sentry (defaults to Vite MODE).
VITE_ENVIRONMENT=


# -----------------------------------------------------------------------------
# Initial admin account (used by init_db.py to bootstrap the first superuser)
# -----------------------------------------------------------------------------

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login


# -----------------------------------------------------------------------------
# SMTP (optional — for sending invitations and notifications)
# -----------------------------------------------------------------------------
# Leave SMTP_HOST empty to disable email sending entirely.

SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=Qualis


# -----------------------------------------------------------------------------
# Audio recording storage (optional — required only for the audio post-sort feature)
# -----------------------------------------------------------------------------
# See backend/.env.s3.example for a fully documented S3/Cellar setup.
# Leave S3_BUCKET_NAME empty to disable audio recordings.

S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

AUDIO_MAX_FILE_SIZE_MB=10
AUDIO_MAX_DURATION_SECONDS=300
