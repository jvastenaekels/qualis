{
    "entry": [
        "src/main.tsx",
        "src/i18n.ts"
    ],
    "project": [
        "src/**/*.{ts,tsx}"
    ],
    "ignore": [
        "src/**/*.test.{ts,tsx}",
        "src/test/**",
        "src/hooks/useFineSortDrag.ts",
        "src/contexts/LayoutContext.context.ts",
        "src/schemas/study.ts",
        "src/api/generated.ts",
        "src/api/model/**",
        "src/components/ui/**",
        "src/styles/**",
        "src/types/*.d.ts",
        "e2e/**"
    ],
    "ignoreExportsUsedInFile": true,
    "ignoreBinaries": [
        "python3"
    ],
    "ignoreDependencies": [
        "@fontsource/google-sans-flex",
        "@dnd-kit/modifiers",
        "next-themes",
        "vaul",
        "@types/dompurify",
        "@axe-core/playwright"
    ]
}
