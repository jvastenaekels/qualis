{
    "name": "qualis",
    "private": true,
    "version": "0.7.0",
    "type": "module",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "biome check src",
        "lint:fix": "biome check --write src",
        "type-check": "tsc -b",
        "format": "biome format --write src",
        "preview": "vite preview",
        "test": "vitest",
        "e2e": "playwright test",
        "e2e:headed": "playwright test --headed",
        "e2e:debug": "playwright test --debug",
        "e2e:report": "playwright show-report",
        "test:e2e:admin": "playwright test --project='Admin E2E' --project='Admin Config Tests' --project='Integration Tests'",
        "test:e2e:study": "playwright test --project='Study E2E' --project='Study Mobile'",
        "i18n-check": "python3 scripts/check_i18n.py",
        "check-interpolations": "python3 scripts/i18n/check_interpolations.py",
        "lint:duplication": "jscpd --config ../.jscpd.json",
        "lint:deadcode": "knip",
        "lint:architecture": "depcruise src --include-only \"^src\" --config .dependency-cruiser.cjs",
        "visualize:deps": "madge --image graph.svg src",
        "check:api": "orval && biome check --fix src/api/generated.ts src/api/model && git diff --exit-code src/api/generated.ts src/api/model",
        "generate:api": "orval && biome check --write src/api"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource/google-sans-flex": "^5.2.1",
        "@hookform/resolvers": "^3.3.0",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@sentry/react": "^10.50.0",
        "@tanstack/react-query": "^5.90.16",
        "@tanstack/react-table": "^8.21.3",
        "@types/dompurify": "^3.0.5",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.0",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dompurify": "^3.4.1",
        "exceljs": "^4.4.0",
        "framer-motion": "^12.23.26",
        "hyphen": "^1.14.1",
        "i18next": "^26.0.8",
        "i18next-browser-languagedetector": "^8.2.0",
        "i18next-http-backend": "^3.0.6",
        "immer": "^11.1.3",
        "lucide-react": "^1.11.0",
        "next-themes": "^0.4.6",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-dropzone": "^14.3.8",
        "react-hook-form": "^7.50.0",
        "react-i18next": "^17.0.4",
        "react-icons": "^5.5.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.11.0",
        "react-zoom-pan-pinch": "^3.7.0",
        "recharts": "^3.6.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^2.2.0",
        "tailwindcss-animate": "^1.0.7",
        "vaul": "^1.1.2",
        "zod": "^3.22.0",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.0",
        "@babel/core": "^7.29.0",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@biomejs/biome": "2.3.10",
        "@faker-js/faker": "^10.2.0",
        "@playwright/test": "^1.57.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.0",
        "@vitest/coverage-v8": "^4.1.5",
        "autoprefixer": "^10.4.17",
        "babel-plugin-react-compiler": "^1.0.0",
        "dependency-cruiser": "^17.3.5",
        "happy-dom": "^20.0.11",
        "jscpd": "^4.0.5",
        "knip": "^5.77.4",
        "madge": "^8.0.0",
        "msw": "^2.12.4",
        "orval": "^7.17.2",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.5"
    }
}
