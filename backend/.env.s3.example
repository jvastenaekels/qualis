# ===================================================================
# Exemple de configuration S3/Cellar pour Libre-Q Audio
# ===================================================================
#
# Copiez ces lignes dans votre fichier .env et remplacez les valeurs
# par vos propres credentials Clever Cloud Cellar.
#
# Pour obtenir ces credentials:
# 1. Connectez-vous à console.clever-cloud.com
# 2. Créez un add-on Cellar
# 3. Notez les credentials affichés
#
# ===================================================================

# S3/Cellar Storage Configuration
# ===================================================================

# Endpoint URL de Clever Cloud Cellar
# Pour région EU (Paris): cellar-c2.services.clever-cloud.com
# Pour région US (Montréal): cellar-c2.services.clever-cloud.com
S3_ENDPOINT_URL=https://cellar-c2.services.clever-cloud.com

# Région AWS compatible (utilisez us-east-1 par défaut)
S3_REGION=us-east-1

# Nom du bucket à créer/utiliser
# IMPORTANT: Doit être unique globalement sur Cellar
# Recommandation: utilisez votre organisation-audio (ex: mycompany-libre-q-audio)
S3_BUCKET_NAME=libre-q-audio

# Access Key ID de Cellar
# Commence généralement par une longue chaîne alphanumérique
# Example: SCWABCDEFGHIJKLMNOP
S3_ACCESS_KEY_ID=your_cellar_access_key_id_here

# Secret Access Key de Cellar
# Longue chaîne alphanumérique (gardez-la secrète!)
# Example: 1234567890abcdef1234567890abcdef12345678
S3_SECRET_ACCESS_KEY=your_cellar_secret_access_key_here


# Audio Recording Limits
# ===================================================================

# Taille maximale par fichier audio en MB
# Recommandé: 10 MB (permet ~5 minutes d'audio Opus)
AUDIO_MAX_FILE_SIZE_MB=10

# Durée maximale d'enregistrement en secondes
# Recommandé: 300 (5 minutes)
AUDIO_MAX_DURATION_SECONDS=300

# Types MIME autorisés pour l'upload
# Ne modifiez pas sauf si vous savez ce que vous faites
# AUDIO_ALLOWED_MIME_TYPES=["audio/webm", "audio/mp4", "audio/mpeg"]


# ===================================================================
# Configuration alternative: Variables Clever Cloud auto-injectées
# ===================================================================
#
# Si vous liez l'add-on Cellar directement à votre application
# Clever Cloud, ces variables seront automatiquement injectées:
#
# CELLAR_ADDON_HOST=cellar-c2.services.clever-cloud.com
# CELLAR_ADDON_KEY_ID=<auto-généré>
# CELLAR_ADDON_KEY_SECRET=<auto-généré>
#
# Dans ce cas, utilisez cette configuration:
#
# S3_ENDPOINT_URL=https://${CELLAR_ADDON_HOST}
# S3_ACCESS_KEY_ID=${CELLAR_ADDON_KEY_ID}
# S3_SECRET_ACCESS_KEY=${CELLAR_ADDON_KEY_SECRET}
# S3_BUCKET_NAME=libre-q-audio
# S3_REGION=us-east-1
#
# ===================================================================


# ===================================================================
# Test de la configuration
# ===================================================================
#
# Après avoir configuré ces variables:
#
# 1. Créez le bucket:
#    python scripts/create_bucket.py
#
# 2. Testez la connexion:
#    python scripts/test_s3_connection.py
#
# 3. Lancez les tests d'intégration:
#    pytest tests/integration/test_audio.py -v
#
# ===================================================================
